APP_NAME=Financial Transaction Processor
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/transactions
REDIS_URL=redis://redis:6379/0
UPLOAD_DIR=/app/storage/uploads
RESULT_DIR=/app/storage/results
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_BATCH_SIZE=10
LLM_TIMEOUT_SECONDS=60
